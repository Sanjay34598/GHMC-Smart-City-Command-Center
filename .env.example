# ============================================================
# DisasterAI — Production Environment Reference
# Copy this file to .env and fill in real values.
# NEVER commit a .env file with real secrets.
# ============================================================

# ─── Database ────────────────────────────────────────────────
POSTGRES_SERVER=db              # Use "localhost" for local dev without Docker
POSTGRES_PORT=5432
POSTGRES_DB=disasterai
POSTGRES_USER=disasterai
POSTGRES_PASSWORD=change_me_in_production

# ─── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:80

# ─── AI — YOLO ───────────────────────────────────────────────
# Set to True to skip real YOLO and use the fast MockDetector instead
USE_MOCK_AI=False
AI_MODEL_PATH=models/best.onnx

# ─── AI — Gemini ─────────────────────────────────────────────
# Leave empty to run in graceful fallback mode (returns pre-written response)
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-1.5-flash

# ─── Frontend (Vite) ─────────────────────────────────────────
# Copy VITE_API_BASE_URL to frontend/.env as well
VITE_API_BASE_URL=http://localhost:8000/api/v1
